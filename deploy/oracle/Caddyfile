{
    email {$ACME_EMAIL}
}

{$API_DOMAIN} {
    encode zstd gzip

    header {
        -Server
        Cache-Control "no-store"
        Referrer-Policy "no-referrer"
        X-Content-Type-Options "nosniff"
    }

    reverse_proxy api:8000 {
        health_uri /health
        health_interval 30s
        health_timeout 5s
    }

    log {
        output stdout
        format console
    }
}
